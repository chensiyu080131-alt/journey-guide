# ===== LLM 大模型配置（旅游攻略生成，浏览器端直连） =====
# 项目为纯静态导出(output: 'export')，无服务端，LLM 由浏览器直连，
# 故 API Key 用 NEXT_PUBLIC_ 前缀（会进入前端 bundle，仅适用于本地/演示）。
# 三项都不填 → 回退到常熟黑客松 OpenAI-Next（2026-07-10 23:59 前可用）。
#
# 免费大模型（任选其一，注册后在控制台拿 API Key 填到 .env.local）：
#
# ① 硅基流动 SiliconFlow（推荐 · 免费 · 国内直连 · OpenAI 兼容）
NEXT_PUBLIC_LLM_BASE_URL=https://api.siliconflow.cn/v1
NEXT_PUBLIC_LLM_API_KEY=在此填入硅基流动 API Key
NEXT_PUBLIC_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#
# ② 智谱 BigModel（glm-4-flash 完全免费，质量好）
#   NEXT_PUBLIC_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#   NEXT_PUBLIC_LLM_MODEL=glm-4-flash
#
# ③ 阿里云百炼 DashScope（qwen-turbo，有免费额度）
#   NEXT_PUBLIC_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   NEXT_PUBLIC_LLM_MODEL=qwen-turbo

# 设为 true 时强制使用 Mock 数据（不走 LLM）
USE_MOCK=false

# 高德地图 Web 端（必填 Key，2021 年后需配对安全密钥）
# 本地：写入 .env.local；生产：GitHub → Settings → Secrets → Actions
NEXT_PUBLIC_AMAP_KEY=your_amap_web_key
NEXT_PUBLIC_AMAP_SECURITY=your_amap_security_js_code
