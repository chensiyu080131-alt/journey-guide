# LLM 配置（服务端，不会暴露到浏览器）
# 平台：OpenAI Next（常熟黑客松）— 接入信息见控制台「接入信息」Tab
LLM_API_KEY=your_openai_next_api_key
LLM_BASE_URL=https://api.openai-next.com/v1
LLM_MODEL=gpt-4o-mini

# 设为 true 时强制使用 Mock 数据
USE_MOCK=false

# 高德地图 Web 端（必填 Key，2021 年后需配对安全密钥）
NEXT_PUBLIC_AMAP_KEY=your_amap_web_key
NEXT_PUBLIC_AMAP_SECURITY=your_amap_security_js_code
