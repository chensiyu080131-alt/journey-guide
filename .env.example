# LLM 配置（服务端，不会暴露到浏览器）
# 所有 AI 调用统一经由后端 /api/chat 与 /api/generate-guide 代理，密钥仅存在于服务端。
# 兼容任意 OpenAI 协议服务：DeepSeek / 通义千问 / OpenAI-Next 等。
LLM_API_KEY=your_api_key

# API 地址与模型（二选一示例）：
#   DeepSeek:     LLM_BASE_URL=https://api.deepseek.com/v1     LLM_MODEL=deepseek-chat
#   OpenAI-Next:  LLM_BASE_URL=https://api.openai-next.com/v1  LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 设为 true 时强制使用 Mock（不配 LLM_API_KEY 时也会自动降级为 Mock 流）
USE_MOCK=false

# 高德 Web 服务（服务端 POI 搜索，可选；未配置则回退 NEXT_PUBLIC_AMAP_KEY）
AMAP_WEB_KEY=your_amap_web_key

# 本地：写入 .env.local
# 生产：GitHub → Settings → Secrets → Actions 添加同名 secret，供 deploy workflow build 使用
# 需在高德控制台配置域名白名单
NEXT_PUBLIC_AMAP_KEY=your_amap_web_key
NEXT_PUBLIC_AMAP_SECURITY=your_amap_security_js_code
